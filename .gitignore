# Local-only archive and scratch files — never committed
.local/
# The pre-rename working copy, kept locally as a backup once relocated here
/retail-rag/

# .NET build output
bin/
obj/
*.user

# Regenerable dev artifacts (placeholder-derived, non-evidential by rule).
# Recursive so per-domain subfolders (e.g. data/corpus/game/) are covered too.
data/corpus/**/generated-placeholder-*
data/corpus/**/ground-truth-placeholder-*

# Runtime state (any location — the API creates its DB and snapshots relative to its CWD)
**/data/*.db
**/data/snapshots/

# Frontend publish bundle (assembled by tools/publish-frontend.ps1)
dist/

# feedctl operator-CLI runtime state (pid file, API log)
.feedctl/
node_modules/
.testbld/

# Local doc-export artifact: the canonical Poro findings live in
# docs/poro-findings.md; the root PDF is a personal export, not a tracked file.
/poro-findings.pdf

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Llm": {
    "Provider": "ollama",
    "BaseUrl": "http://localhost:11434",
    "Models": {
      "Structuring": "hf.co/mradermacher/Llama-Poro-2-8B-Instruct-GGUF:Q4_K_M",
      "Synthesis": "hf.co/mradermacher/Llama-Poro-2-8B-Instruct-GGUF:Q4_K_M"
    }
  },
  "Structuring": {
    "PromptPath": "prompts/structuring-v0.txt",
    "Temperature": 0,
    "MaxOutputTokens": 512
  },
  "Report": {
    "SnapshotDir": "data/snapshots",
    "SynthesisPromptPath": "prompts/synthesis-v0.txt",
    "AlertNominationPromptPath": "prompts/alert-nomination-v0.txt",
    "SynthesisTemperature": 0.3,
    "SynthesisMaxOutputTokens": 700,
    "MaxItemsPerLlmCall": 60,
    "ExcerptChars": 120,
    "AlertNominationEnabled": true,
    "DefaultWindowDays": 7,
    "MaxWindowDays": 92,
    "MaxItemsPerWindow": 2000
  },
  "Ingest": {
    "InputMaxChars": 800,
    "MaxBodyBytes": 16384,
    "RateLimitRequests": 30,
    "RateLimitWindowSeconds": 60,
    "RateLimitExemptLoopback": true,
    "LlmMaxConcurrency": 2,
    "LlmAcquireTimeoutMs": 500,
    "DbPath": "data/feedback.db",
    "AlertKeywordsPath": "config/alert-keywords.json",
    "AllowedSources": ["google_review", "email", "web_form", "desk"],
    "AllowedCorsOrigins": []
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Domain": {
    "Active": "retail",
    "Root": "domains"
  },
  "Llm": {
    "Provider": "ollama",
    "BaseUrl": "http://localhost:11434",
    "Models": {
